{
  "name": "edulab-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "desktop:prepare-env": "node desktop/prepare-env.cjs",
    "desktop:pack": "npm run build && npm run desktop:prepare-env && electron-builder --mac dir --arm64",
    "desktop:build": "npm run build && npm run desktop:prepare-env && electron-builder --mac dmg --arm64",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "main": "desktop/main.cjs",
  "build": {
    "appId": "uz.labproof.admin",
    "productName": "LabProof Admin",
    "artifactName": "LabProof-Admin-${version}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "desktop/**"
    ],
    "files": [
      "desktop/main.cjs",
      "desktop/preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app"
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "app/node_modules"
      },
      {
        "from": ".next/static",
        "to": "app/.next/static"
      },
      {
        "from": "public",
        "to": "app/public"
      },
      {
        "from": "desktop/runtime.env",
        "to": "app/.env"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.46.1",
    "@swc/helpers": "^0.5.21",
    "@tanstack/react-query": "^5.59.16",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^5.24.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.3",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "wait-on": "^9.0.10"
  }
}
